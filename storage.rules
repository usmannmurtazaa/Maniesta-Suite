// ⚠️ These storage rules are intended for a future file‑upload feature.
// Currently, the application does not upload files to Firebase Storage.
// Review and tighten these rules (e.g., requiring authentication) before enabling uploads.
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /exports/{fileName} {
      allow write: if request.resource.contentType.matches('(application/pdf|text/csv)')
                   && request.resource.size < 5 * 1024 * 1024; // 5 MB
      allow read: if true;
      allow delete: false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}